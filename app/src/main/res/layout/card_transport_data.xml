<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Vehicle Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_directions"
                app:tint="#1976D2" />

            <TextView
                android:id="@+id/tvVehicle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Vehicle No"
                android:textColor="#1E293B"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- 3 Dot Menu -->
            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_more"
                android:background="@android:color/transparent"
                android:contentDescription="menu"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#EDF2F7" />

        <!-- Factory / Weight / Date -->
        <TextView
            android:id="@+id/tvFactory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Factory Name"
            android:textColor="#4A5568" />

        <TextView
            android:id="@+id/tvWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Weight Info"
            android:textColor="#4A5568"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:text="Date"
            android:textColor="#718096"
            android:textSize="12sp" />

        <!-- Buy Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="BUY DETAILS"
            android:textStyle="bold"
            android:textColor="#1976D2" />

        <TextView
            android:id="@+id/tvBuyWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buy Weight"
            android:textColor="#4A5568" />

        <TextView
            android:id="@+id/tvBuyPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buy Price"
            android:textColor="#4A5568" />

        <TextView
            android:id="@+id/tvBuyGST"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buy GST"
            android:textColor="#4A5568" />

        <TextView
            android:id="@+id/tvBuyTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buy Total"
            android:textColor="#4A5568"
            android:textStyle="bold" />

        <!-- Sell Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="SELL DETAILS"
            android:textStyle="bold"
            android:textColor="#D32F2F" />

        <TextView
            android:id="@+id/tvSellPerson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sell Person"
            android:textColor="#4A5568" />

        <TextView
            android:id="@+id/tvSellWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sell Weight"
            android:textColor="#4A5568" />

        <TextView
            android:id="@+id/tvSellPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sell Price"
            android:textColor="#4A5568" />

        <TextView
            android:id="@+id/tvSellGST"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sell GST"
            android:textColor="#4A5568" />

        <TextView
            android:id="@+id/tvSellTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sell Total"
            android:textColor="#4A5568"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>