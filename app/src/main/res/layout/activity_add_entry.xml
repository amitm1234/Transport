<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Page Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Logistics Data Entry"
            android:textColor="#1A1A1A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:shadowColor="#00000020" />

        <!-- Entry Type Spinner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Entry Type"
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerEntryType"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/spinner_background"
                    android:padding="12dp"
                    android:gravity="center_vertical" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vehicle & Date Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGeneral"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle &amp; Date"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="16dp"
                    android:drawableStart="@drawable/ic_local_shipping"
                    android:drawablePadding="10dp"
                    android:drawableTint="#1565C0" />

                <!-- Vehicle Number -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Vehicle Number"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575">

                    <AutoCompleteTextView
                        android:id="@+id/etVehicleNo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:textAllCaps="true"
                        android:textColor="#212121"
                        android:inputType="textCapCharacters"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Weight + Unit Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_weight="1.8"
                        android:layout_height="wrap_content"
                        android:hint="Weight"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#BDBDBD"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="#757575">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etWeight"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="numberDecimal"
                            android:textColor="#212121"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Spinner
                        android:id="@+id/spMeasurement"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1.2"
                        android:background="@drawable/spinner_background"
                        android:padding="12dp"
                        android:gravity="center_vertical" />
                </LinearLayout>

                <!-- Date -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Select Date"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_calendar"
                    app:endIconTint="#757575">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDate"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="false"
                        android:textColor="#212121"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Factory Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Factory Details"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="16dp"
                    android:drawableStart="@drawable/ic_factory"
                    android:drawablePadding="10dp"
                    android:drawableTint="#1565C0" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Sugar Factory Name"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575"
                    app:startIconDrawable="@drawable/ic_factory"
                    app:startIconTint="#757575">

                    <AutoCompleteTextView
                        android:id="@+id/etFactory"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:textColor="#212121"
                        android:inputType="textCapWords"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buy Details Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBuy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buy Details"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="16dp"
                    android:drawableStart="@drawable/ic_shopping_cart"
                    android:drawablePadding="10dp"
                    android:drawableTint="#1565C0" />

                <!-- Buy Price -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Buy Price"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575"
                    app:prefixText="₹">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBuyPrice"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:textColor="#212121"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- GST % -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="GST %"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575"
                    app:suffixText="%">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBuyGSTPercent"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:textColor="#212121"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:text="18" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- GST Amount | Total Amount Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- GST Amount -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="GST Amount"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#BDBDBD"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="#757575"
                        app:prefixText="₹">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBuyGST"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:enabled="false"
                            android:textColor="#616161"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Total Amount -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_weight="2"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:hint="Total Amount"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#BDBDBD"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="#757575"
                        app:prefixText="₹">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBuyTotal"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:enabled="false"
                            android:textColor="#212121"
                            android:textStyle="bold"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sell Details Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSell"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sell Details"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="16dp"
                    android:drawableStart="@drawable/ic_sell"
                    android:drawablePadding="10dp"
                    android:drawableTint="#1565C0" />

                <!-- Sell Person -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Sell Person"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575">

                    <AutoCompleteTextView
                        android:id="@+id/etSellPerson"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:textColor="#212121"
                        android:inputType="textCapWords"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Sell Weight -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Sell Weight"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSellWeight"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:textColor="#212121"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Sell Price -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Sell Price"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575"
                    app:prefixText="₹">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSellPrice"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:textColor="#212121"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- GST % -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="GST %"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#BDBDBD"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintTextColor="#757575"
                    app:suffixText="%">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSellGSTPercent"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:textColor="#212121"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:text="18" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- GST Amount | Total Amount Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- GST Amount -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="GST Amount"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#BDBDBD"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="#757575"
                        app:prefixText="₹">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSellGST"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:enabled="false"
                            android:textColor="#616161"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Total Amount -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_weight="2"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:hint="Total Amount"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#BDBDBD"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="#757575"
                        app:prefixText="₹">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSellTotal"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:enabled="false"
                            android:textColor="#212121"
                            android:textStyle="bold"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Scrollable Indicator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Bottom Buttons Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp">

            <!-- Submit Data Button -->
            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#1565C0"
                android:elevation="6dp"
                android:stateListAnimator="@null"
                android:text="Submit Data"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="#1565C0"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
