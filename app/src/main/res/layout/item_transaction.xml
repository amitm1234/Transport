<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3">

        <!-- Factory Box -->
        <LinearLayout
            android:id="@+id/layoutItemFactory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_factory"
                app:tint="#64748B" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Factory"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemFactory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Factory A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Vehicle Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_vehicles"
                app:tint="#3B82F6" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemVehicle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MH12AB1234"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Weight Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/scale_icon"
                app:tint="#376DC8" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weight"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3,200 kg"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sell Price Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_shopping_cart"
                app:tint="#64748B" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sell Price"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- GST Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/gst_icon"
                app:tint="#120303" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:id="@+id/txtItemGSTLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GST"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemGST"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Total Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/coin"
                app:tint="#E4CB0A" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Date Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar"
                app:tint="#64748B" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18 Nov 2024"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

    </GridLayout>

</com.google.android.material.card.MaterialCardView>
