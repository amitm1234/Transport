<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2">

        <!-- Vehicle Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_vehicles"
                app:tint="#3B82F6" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemVehicle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MH12AB1234"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Weight Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/scale_icon"
                app:tint="#64748B" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weight"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5,000 kg"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Buy Price Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_shopping_cart"
                app:tint="#64748B" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buy Price"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemBuyPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 15,000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sell Person Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_person"
                app:tint="#64748B" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sell Person"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemSellPerson"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rahul"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Date Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar"
                app:tint="#64748B" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20/03/2026"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Remaining Advance Box -->
        <LinearLayout
            android:id="@+id/layoutRemainingAdvance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_item_border">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/pocket"
                app:tint="#10B981" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remaining"
                    android:textSize="10sp"
                    android:textColor="#64748B" />
                <TextView
                    android:id="@+id/txtItemRemainingAdvance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 35,000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#10B981" />
            </LinearLayout>
        </LinearLayout>

    </GridLayout>

</com.google.android.material.card.MaterialCardView>
